PORT=3000
NODE_ENV=development

# Facebook App Credentials
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_VERIFY_TOKEN=your_custom_verify_token_here
FB_APP_SECRET=your_app_secret_here

# Bot Settings
BOT_PREFIX=/
COMMANDS_DIR=src/commands/definitions
# Comma-separated Facebook user IDs with admin privileges
BOT_ADMIN_IDS=

# Database
MONGODB_URI=mongodb://localhost:27017/sixsu-bot

# Cache — Redis (optional)
# Leave empty to use in-memory cache (data lost on restart).
# Set to enable persistent caching across restarts.
# REDIS_URL=redis://localhost:6379

# Auth / Session
SESSION_SECRET=change_me_to_a_random_32_char_string
# FB_APPSTATE=<base64-encoded appstate JSON>
# FB_APPSTATE_FILE=data/appstate.json
# FB_SESSION_FILE=data/sessions.json
# FB_SESSION_TTL_DAYS=30

# Logger
LOG_LEVEL=info
LOG_DIR=logs
LOG_FILE=true
